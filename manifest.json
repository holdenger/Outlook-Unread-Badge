{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "version": "0.1.2",
  "description": "__MSG_extDescription__",
  "icons": {
    "16": "icons/Outlook-Badge-16.png",
    "32": "icons/Outlook-Badge-32.png",
    "48": "icons/Outlook-Badge-48.png",
    "128": "icons/Outlook-Badge-128.png"
  },
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": [
        "settings-store.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected-bridge.js"
      ],
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.cloud.microsoft/*"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/Outlook-Badge-16.png",
      "32": "icons/Outlook-Badge-32.png"
    },
    "default_title": "__MSG_actionDefaultTitle__",
    "default_popup": "popup.html"
  }
}
